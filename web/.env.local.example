# Copy this file to .env.local and fill in real values. .env.local is
# already gitignored (see .gitignore's ".env*" rule) — never commit it.

# ── Supabase (Session 19 scaffold — schema exists, not wired up yet) ───────
# Create a free Supabase project at https://supabase.com/dashboard — no
# payment method is required for the free tier. Then, in Project Settings →
# API, copy:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — same page, "service_role" secret. Server-only, never
# exposed to the browser (do not prefix with NEXT_PUBLIC_). Used for
# privileged operations like inviting a Bataka Panel officer.
SUPABASE_SERVICE_ROLE_KEY=

# ── Payments (not started) ──────────────────────────────────────────────────
# Blocked on choosing/obtaining MTN MoMo / Airtel Money / other provider
# credentials. The One-time gift and Sacco fee flows (web/components/give/)
# stay mocked until these exist — don't add placeholder vars for a provider
# that hasn't been chosen yet.
